{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "agentation": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "agentation-mcp",
        "server"
      ],
      "enabled": true,
      "environment": {}
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa,company_research_exa,people_search_exa",
      "enabled": true
    },
    "contextplus": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "contextplus"
      ],
      "enabled": true,
      "environment": {
        "OLLAMA_EMBED_MODEL": "nomic-embed-text-v2-moe:latest",
        "OLLAMA_CHAT_MODEL": "gemma2:27b",
        "OLLAMA_API_KEY": "OLLAMA_API_KEY",
        "CONTEXTPLUS_EMBED_BATCH_SIZE": "8",
        "CONTEXTPLUS_EMBED_TRACKER": "lazy"
      }
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": [
        "uvx ty server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  }
}